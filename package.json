  "scripts": {
    "preinstall": "node tools/nodeVersionCheck.js",
    "start-message": "babel-node tools/startMessage.js",
    "prestart": "babel src --out-dir dist",
    "start": "npm-run-all --parallel open:src",
    "start:server": "node server/build/server.js",
    "ssr": "npm run clean-ssr && npm run build:client && npm run build:server && npm run start:server",
    "heroku-postbuild": "npm run build:client && npm run build:server",
    "open:src": "babel-node tools/srcServer.js",
    "open:dist": "babel-node tools/distServer.js",
    "lint:code": "eslint webpack/webpack.config.* src tools server --color",
    "lint:style": "stylelint \"src/styles/**/*.scss\"",
    "lint": "eslint src/**/*.js src/**/*.jsx",
    "clean-dist": "npm run remove-dist && mkdir dist",
    "clean-ssr": "rimraf ./server/build",
    "remove-dist": "rimraf ./dist",
    "prebuild": "npm run clean-dist && npm run lint && npm run test",
    "build": "babel-node tools/build.js",
    "build:server": "babel-node server/scripts/buildServer.js",
    "build:client": "babel-node server/scripts/buildClient.js",
    "test": "jest",
    "test:cover": "npm run test -- --coverage",
    "test:watch": "npm run test -- --watch",
    "deploy": "npm run build && babel-node tools/deployS3",
    "analyze-bundle": "babel-node ./tools/analyzeBundle.js"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "jsx"
    ],
    "moduleNameMapper": {
      "\\.(css|scss|less|jpg|jpeg|png)$": "identity-obj-proxy"
    }
  }
